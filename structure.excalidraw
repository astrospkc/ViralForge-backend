    {
      "id": "sklxwqESVPxSCZLzfaV97",
      "type": "text",
      "x": -342.6058683166508,
      "y": 3740.4401648864764,
      "width": 434.1596374511719,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ak",
      "roundness": null,
      "seed": 1006485204,
      "version": 111,
      "versionNonce": 1027979500,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "Uk10ddArlpyME_vsA_ECF",
          "type": "arrow"
        }
      ],
      "updated": 1772800579623,
      "link": null,
      "locked": false,
      "text": "This approach post-processes videos by\nsplitting them into small segments (each a\nplayable unit that's a few seconds in length)\nand then converts each segment into\ndifferent formats playable on different\ndevices. This is a strictly better design\nthan the previous design because it enables\nmore efficient video streaming later, which\nwe will clarify as we design our system.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This approach post-processes videos by splitting them into small segments (each a playable unit that's a few seconds in length) and then converts each segment into different formats playable on different devices. This is a strictly better design than the previous design because it enables more efficient video streaming later, which we will clarify as we design our system.",
      "autoResize": false,
      "lineHeight": 1.25
    },
