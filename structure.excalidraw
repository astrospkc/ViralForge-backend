      "link": null,
      "locked": false,
      "text": "File                        Role\n──────────────────────────────────────────────────────\ntask_transcode.go           defines job + payload struct\nhandler_transcode.go        does the actual work (your HLSTranscode)\nworkers/server.go           runs asynq, registers handlers, sets concurrency\nhandlers/video.go           enqueues job after saving to DB\nmain.go                     starts both HTTP + worker server",
      "fontSize": 16,
      "fontFamily": 7,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "File                        Role\n──────────────────────────────────────────────────────\ntask_transcode.go           defines job + payload struct\nhandler_transcode.go        does the actual work (your HLSTranscode)\nworkers/server.go           runs asynq, registers handlers, sets concurrency\nhandlers/video.go           enqueues job after saving to DB\nmain.go                     starts both HTTP + worker server",
      "autoResize": true,
      "lineHeight": 1.15
    },
